{
  // ===== UI & Workbench =====
  "window.commandCenter": false,
  "workbench.layoutControl.enabled": false,
  "window.menuBarVisibility": "toggle",
  "window.titleBarStyle": "custom",
  "workbench.activityBar.location": "top",
  "workbench.statusBar.visible": true,
  "workbench.editor.empty.hint": "hidden",
  "workbench.startupEditor": "none",
  "window.titleSeparator": " ",
  "workbench.productIconTheme": "material-product-icons",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 10,
  "workbench.editor.limit.perEditorGroup": true,
  "workbench.colorTheme": "Tsoding Gruber Darker",

  // ===== Editor =====
  "editor.fontSize": 18,
  "editor.fontFamily": "'Iosevka Nerd Font', 'Iosevka Nerd Font Mono', Consolas, Menlo, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.minimap.enabled": false,
  "editor.lineNumbers": "relative",
  "editor.scrollBeyondLastLine": false,
  "editor.cursorSurroundingLines": 8,
  "editor.smoothScrolling": true,
  "editor.formatOnPaste": true,
  "editor.stickyScroll.enabled": true,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.accessibilitySupport": "off",
  "editor.renderLineHighlight": "none",
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": false,
  "editor.guides.bracketPairs": "active",
  "editor.hideCursorInOverviewRuler": true,
  "editor.overviewRulerBorder": false,
  "editor.cursorBlinking": "blink",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleDeclarations": "goto",
  "editor.gotoLocation.multipleTypeDefinitions": "goto",
  "editor.gotoLocation.multipleImplementations": "peek",
  "editor.gotoLocation.multipleReferences": "peek",
  "editor.linkedEditing": true,
  "editor.experimental.asyncTokenization": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.inlineSuggest.enabled": true,

  // ===== Files & Explorer =====
  "files.autoSave": "afterDelay",
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "files.associations": {
    "*.env": "properties",
  },
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "{hexdiff}:/**/*.*": "hexEditor.hexedit",
    "*.pdf": "latex-workshop-pdf-hook",
  },
  // ===== Terminal =====
  "terminal.integrated.fontFamily": "'Iosevka Nerd Font Mono', monospace",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.commandsToSkipShell": ["matlab.interrupt"],
  "terminal.integrated.gpuAcceleration": "on",

  // ===== Git =====
  "git.autofetch": "all",
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",

  // ===== Languages & Formatters =====
  "powershell.integratedConsole.showOnStartup": false,
  "C_Cpp.clang_format_style": "Google",
  "C_Cpp.default.cppStandard": "gnu++23",
  "C_Cpp.default.cStandard": "gnu23",
  "C_Cpp.autoAddFileAssociations": false,
  "java.format.settings.url": "https://raw.githubusercontent.com/google/styleguide/gh-pages/eclipse-java-google-style.xml",
  "java.format.settings.profile": "GoogleStyle",
  "java.project.importOnFirstTimeStartup": "interactive",
  "go.toolsManagement.autoUpdate": true,
  "xml.server.vmargs": "-Xmx128M",
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.tabSize": 2,
  },
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.tabSize": 2,
  },
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit",
    },
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers",
  },
  "[dockercompose]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers",
  },
  "[nginx]": {
    "editor.defaultFormatter": "ahmadalli.vscode-nginx-conf",
  },
  // ===== Tools & Integrations =====
  "prettier.tabWidth": 2,
  "prettier.printWidth": 120,
  "Workspace_Formatter.includePattern": [
    "*.c",
    "*.cpp",
    "*.java",
    "*.js",
    "*.md",
    "*.html",
    "*.json",
    "*.yaml",
    "*.yml",
  ],
  "cmake.enabledOutputParsers": ["cmake", "msvc", "gcc", "gnuld", "ghs", "diab"],
  "cmake.pinnedCommands": ["workbench.action.tasks.configureTaskRunner", "workbench.action.tasks.runTask"],
  "cmake.automaticReconfigure": false,
  "cmake.configureOnEdit": false,
  "cmake.configureOnOpen": false,
  "makefile.configureOnOpen": true,
  "latex-workshop.formatting.latex": "latexindent",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "scminput": false,
    "cpp": false,
    "c": false,
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.agent.enabled": true,
  "chat.mcp.gallery.enabled": true,
  "chat.tools.urls.autoApprove": {
    "https://nextjs.org": {
      "approveRequest": false,
      "approveResponse": true,
    },
  },
  "chat.viewSessions.orientation": "stacked",
  "remote.SSH.remotePlatform": {
    "m4tr1x": "linux",
    "libreelec": "linux",
  },
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:claude-sonnet-4.6",
  "settingsSync.ignoredExtensions": [
    "jjaroztegi.vscode-altitude-script-language",
    "ms-vscode-remote.remote-wsl",
  ],

  // ===== Security & Telemetry =====
  "security.workspace.trust.untrustedFiles": "open",
  "telemetry.telemetryLevel": "off",
  "MATLAB.telemetry": false,
  "redhat.telemetry.enabled": false,
  "gitlens.telemetry.enabled": false,

  // ===== Performance =====
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1,
  },
  "diffEditor.ignoreTrimWhitespace": false,

  // ===== Vim =====
  "vim.enableNeovim": true,
  // --- Core ---
  "vim.leader": "<space>",
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.smartRelativeLine": true,
  "vim.easymotion": true,
  "vim.sneak": true,
  "vim.surround": true,
  "vim.foldfix": true,
  "vim.incsearch": true,
  "vim.hlsearch": true,
  "vim.searchMatchTextColor": "#0a0a0a",
  "vim.searchHighlightTextColor": "#0a0a0a",
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.duration": 200,
  // --- Handle Keys ---
  "vim.handleKeys": {
    "<C-d>": true,
    "<C-u>": true,
    "<C-f>": false,
    "<C-b>": false,
    "<C-h>": false,
    "<C-j>": false,
    "<C-k>": false,
    "<C-l>": false,
    "<C-w>": false,
    "<C-s>": false,
    "<C-a>": false,
    "<C-c>": false,
    "<C-v>": false,
    "<C-z>": false,
  },

  // --- Insert Mode ---
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"],
    },
    {
      "before": ["j", "j"],
      "after": ["<Esc>"],
    },
  ],

  // --- Normal Mode ---
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "?"],
      "commands": ["whichkey.show"],
    },
    {
      "before": ["<leader>", "d"],
      "after": ["d", "d"],
    },
    {
      "before": ["<Esc>"],
      "commands": [":nohl"],
    },
    {
      "before": ["<leader>", "u", "r"],
      "commands": [":nohl"],
    },
    {
      "before": ["<C-n>"],
      "commands": [":nohl"],
    },
    {
      "before": ["K"],
      "commands": ["editor.action.showHover"],
    },
    {
      "before": ["<leader>", "<space>"],
      "commands": ["workbench.action.quickOpen"],
    },
    {
      "before": ["<leader>", ","],
      "commands": ["workbench.action.showAllEditors"],
    },
    {
      "before": ["<leader>", "/"],
      "commands": ["workbench.action.findInFiles"],
    },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"],
    },
    {
      "before": ["<leader>", "f", "r"],
      "commands": ["workbench.action.openRecent"],
    },
    {
      "before": ["<leader>", "f", "n"],
      "commands": ["workbench.action.files.newUntitledFile"],
    },
    {
      "before": ["<leader>", "f", "b"],
      "commands": ["workbench.action.showAllEditors"],
    },
    {
      "before": ["<leader>", "f", "e"],
      "commands": ["workbench.files.action.showActiveFileInExplorer"],
    },
    {
      "before": ["<leader>", "f", "t"],
      "commands": ["workbench.action.terminal.toggleTerminal"],
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.action.toggleSidebarVisibility"],
    },
    {
      "before": ["<leader>", "E"],
      "commands": ["workbench.files.action.focusFilesExplorer"],
    },
    {
      "before": ["<leader>", "s", "g"],
      "commands": ["workbench.action.findInFiles"],
    },
    {
      "before": ["<leader>", "s", "w"],
      "commands": ["workbench.action.findInFiles"],
    },
    {
      "before": ["<leader>", "s", "r"],
      "commands": ["workbench.action.replaceInFiles"],
    },
    {
      "before": ["<leader>", "s", "s"],
      "commands": ["workbench.action.gotoSymbol"],
    },
    {
      "before": ["<leader>", "s", "S"],
      "commands": ["workbench.action.showAllSymbols"],
    },
    {
      "before": ["<leader>", "s", "k"],
      "commands": ["workbench.action.openGlobalKeybindings"],
    },
    {
      "before": ["<leader>", "s", "c"],
      "commands": ["workbench.action.showCommands"],
    },
    {
      "before": ["<leader>", "s", "h"],
      "commands": ["workbench.action.showAllCommands"],
    },
    {
      "before": ["<leader>", "c", "a"],
      "commands": ["editor.action.quickFix"],
    },
    {
      "before": ["<leader>", "c", "A"],
      "commands": ["editor.action.sourceAction"],
    },
    {
      "before": ["<leader>", "c", "f"],
      "commands": ["editor.action.formatDocument"],
    },
    {
      "before": ["<leader>", "c", "F"],
      "commands": ["editor.action.formatSelection"],
    },
    {
      "before": ["<leader>", "c", "r"],
      "commands": ["editor.action.rename"],
    },
    {
      "before": ["<leader>", "c", "d"],
      "commands": ["editor.action.showHover"],
    },
    {
      "before": ["<leader>", "c", "l"],
      "commands": ["workbench.action.problems.focus"],
    },
    {
      "before": ["<leader>", "c", "o"],
      "commands": ["editor.action.organizeImports"],
    },
    {
      "before": ["g", "d"],
      "commands": ["editor.action.revealDefinition"],
    },
    {
      "before": ["g", "D"],
      "commands": ["editor.action.revealDeclaration"],
    },
    {
      "before": ["g", "r"],
      "commands": ["editor.action.goToReferences"],
    },
    {
      "before": ["g", "I"],
      "commands": ["editor.action.goToImplementation"],
    },
    {
      "before": ["g", "y"],
      "commands": ["editor.action.goToTypeDefinition"],
    },
    {
      "before": ["g", "K"],
      "commands": ["editor.action.triggerParameterHints"],
    },
    {
      "before": ["<leader>", "b", "b"],
      "commands": ["workbench.action.showAllEditors"],
    },
    {
      "before": ["<leader>", "b", "d"],
      "commands": ["workbench.action.closeActiveEditor"],
    },
    {
      "before": ["<leader>", "b", "D"],
      "commands": ["workbench.action.closeOtherEditors"],
    },
    {
      "before": ["<leader>", "b", "o"],
      "commands": ["workbench.action.closeOtherEditors"],
    },
    {
      "before": ["<leader>", "b", "p"],
      "commands": ["workbench.action.pinEditor"],
    },
    {
      "before": ["<leader>", "b", "P"],
      "commands": ["workbench.action.unpinEditor"],
    },
    {
      "before": ["<leader>", "`"],
      "commands": ["workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup"],
    },
    {
      "before": ["<S-h>"],
      "commands": [":bprev"],
    },
    {
      "before": ["<S-l>"],
      "commands": [":bnext"],
    },
    {
      "before": ["<leader>", "g", "g"],
      "commands": ["workbench.view.scm"],
    },
    {
      "before": ["<leader>", "g", "b"],
      "commands": ["gitlens.toggleFileBlame"],
    },
    {
      "before": ["<leader>", "g", "B"],
      "commands": ["gitlens.openFileOnRemote"],
    },
    {
      "before": ["<leader>", "g", "d"],
      "commands": ["git.openChange"],
    },
    {
      "before": ["<leader>", "g", "l"],
      "commands": ["gitlens.showQuickFileHistory"],
    },
    {
      "before": ["<leader>", "g", "L"],
      "commands": ["gitlens.showQuickRepoHistory"],
    },
    {
      "before": ["<leader>", "g", "c"],
      "commands": ["gitlens.showQuickCommitDetails"],
    },
    {
      "before": ["<leader>", "w", "d"],
      "commands": ["workbench.action.closeActiveEditor"],
    },
    {
      "before": ["<leader>", "w", "w"],
      "commands": ["workbench.action.focusNextGroup"],
    },
    {
      "before": ["<leader>", "w", "m"],
      "commands": ["workbench.action.toggleEditorWidths"],
    },
    {
      "before": ["<leader>", "-"],
      "commands": ["workbench.action.splitEditorDown"],
    },
    {
      "before": ["<leader>", "|"],
      "commands": ["workbench.action.splitEditorRight"],
    },
    {
      "before": ["<leader>", "x", "x"],
      "commands": ["workbench.action.problems.focus"],
    },
    {
      "before": ["<leader>", "x", "X"],
      "commands": ["workbench.actions.view.problems"],
    },
    {
      "before": ["<leader>", "u", "w"],
      "commands": ["editor.action.toggleWordWrap"],
    },
    {
      "before": ["<leader>", "u", "z"],
      "commands": ["workbench.action.toggleZenMode"],
    },
    {
      "before": ["<leader>", "q", "q"],
      "commands": ["workbench.action.closeWindow"],
    },
    {
      "before": ["<leader>", "q", "a"],
      "commands": ["workbench.action.quit"],
    },
  ],

  // --- Visual Mode ---
  "vim.visualModeKeyBindings": [
    {
      "before": ["<leader>", "?"],
      "commands": ["whichkey.show"],
    },
    {
      "before": ["<"],
      "after": ["<", "g", "v"],
    },
    {
      "before": [">"],
      "after": [">", "g", "v"],
    },
    {
      "before": ["<leader>", "/"],
      "commands": ["workbench.action.findInFiles"],
    },
    {
      "before": ["<leader>", "c", "a"],
      "commands": ["editor.action.quickFix"],
    },
    {
      "before": ["<leader>", "c", "f"],
      "commands": ["editor.action.formatSelection"],
    },
    {
      "before": ["g", "c"],
      "commands": ["editor.action.commentLine"],
    },
  ],

  // ===== Other Settings =====
  "altitudeScriptLanguage.compiler.enabled": true,
  "altitudeScriptLanguage.compiler.installRoot": "D:\\Program Files (x86)\\Altitude\\Altitude uCI 8\\Altitude Script Developer\\bin",
  "altitudeScriptLanguage.compiler.runOnType": true
}
